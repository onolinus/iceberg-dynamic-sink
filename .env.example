# Copy this file to .env and fill in the real values.
# docker compose automatically loads .env — never commit .env to git.

# Alibaba Cloud OSS credentials
OSS_ACCESS_KEY_ID=your-oss-access-key-id-here
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret-here

# Optional overrides (defaults already hardcoded in the job)
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# HIVE_METASTORE_URI=thrift://localhost:9083
# CATALOG_NAMESPACE=raw
# KAFKA_TOPICS_PATTERN=.*
# KAFKA_STARTING_OFFSET=latest
# WRITE_PARALLELISM=2
